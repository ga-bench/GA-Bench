#!/bin/bash
#PBS -N mist_t1_vB_s1
#PBS -l select=1:ncpus=8:ngpus=1:mem=64gb
#PBS -l walltime=240:00:00
#PBS -j oe
#PBS -o ./logs/job.out

###############################################################################
# Task 1 / Variant B / Stage 1 SRP Inference  (MULTIMODAL: text + figures)
# Model: Mistral-Small-3.1-24B-Instruct  W4A16 (compressed-tensors, 4-bit weights)
# Infra: SINGLE node, 1 GPU (A100 40GB), vLLM TP=1, NO Ray.
# Images are sent as base64 by the Python script, so NO --allowed-local-media-path.
#
# Submit one PBS file as TWO jobs (each gets its own node), passing only HALF:
#   qsub -v HALF=1 task1_variantB_stage1_mistral_small_24b_job.pbs
#   qsub -v HALF=2 task1_variantB_stage1_mistral_small_24b_job.pbs
#
# Mistral specifics (proven in load test):
#   - --quantization compressed-tensors  --dtype float16
#   - NO tokenizer_mode=mistral  (HF tokenizer required for the Pixtral image
#     processor; mistral mode breaks on 'convert_tokens_to_ids').
#   - Mistral uses a system role (unlike Gemma).
###############################################################################

set -euo pipefail
ulimit -n 65535 2>/dev/null || true

HALF="${HALF:?Submit with -v HALF=1 or -v HALF=2}"

# ----------------------------------------------------------------------------
# Paths: inputs from ORIGINAL tree, outputs to NEW _awq tree
# ----------------------------------------------------------------------------
INPUT_BASE="./task1_completeness/variant_B"
OUTPUT_BASE="./task1_completeness_awq/variant_B"

CODE_DIR="${OUTPUT_BASE}/codes"
PBS_DIR="${OUTPUT_BASE}/pbs"
OUTPUT_DIR="${OUTPUT_BASE}/outputs/stage1/mistral_small_24b"
LOG_DIR="${OUTPUT_DIR}/logs"
REPORT_DIR="${OUTPUT_DIR}/reports"
SRP_DIR="${OUTPUT_DIR}/srps"
RAW_DIR="${OUTPUT_DIR}/raw_outputs"
ERROR_DIR="${OUTPUT_DIR}/errors"
CHECKPOINT_DIR="${OUTPUT_DIR}/checkpoints"

SCRIPT_PATH="${CODE_DIR}/task1_variantB_stage1_mistral_small_24b_inference.py"
SYSTEM_PROMPT_FILE="${INPUT_BASE}/system_prompts/task1_variantB_phase1_system_prompt.txt"
FIGURE_PATHS_CSV="${INPUT_BASE}/user_prompts/task1_variantB_phase1_figure_paths.csv"

# AWQ env (separate from the original llm_env, which the running jobs use)
ENV_DIR="./environments/llm_env_awq"
PYTHON_BIN="${ENV_DIR}/bin/python3"
# Python.h headers live in the ORIGINAL env; reuse for Triton JIT.
PYTHON_INCLUDE="./environments/llm_env/include/python3.12"

MODEL_PATH="./models/awq/Mistral-Small-3.1-24B-Instruct-w4a16"
SERVED_MODEL_NAME="mistral_small_24b"
VLLM_PORT="8000"

# vLLM W4A16 settings. Mistral-24B weights are small (~14 GiB), so a 57344
# context + 15 images fit with KV headroom on one 40GB card (this is the same
# context the Qwen-32B AWQ ran at here). 57344 (up from 40960) lets the handful
# of text-heavy papers whose prompt+images reached 41k-47k tokens finish, and
# leaves room for the larger 8192 output budget on entity-heavy SRPs.
MAX_MODEL_LEN="49152"
MAX_NUM_SEQS="1"
GPU_MEMORY_UTILIZATION="0.95"

# Multimodal encoder-cache / batched-token budget. Kept equal to the context so
# the encoder cache can hold every figure's image tokens for a full prompt.
MAX_NUM_BATCHED_TOKENS="8192"

# Inference test controls. Full run: TEST_ARGS=""
TEST_ARGS=""
MAX_IMAGES="15"  # at most 15 images/paper, matching server --limit-mm-per-prompt image:15

mkdir -p "${LOG_DIR}" "${REPORT_DIR}" "${SRP_DIR}" "${RAW_DIR}" "${ERROR_DIR}" "${CHECKPOINT_DIR}" "${PBS_DIR}"

# ----------------------------------------------------------------------------
# Compute this half's index range from the CSV row count (minus header)
# ----------------------------------------------------------------------------
if [[ ! -f "${FIGURE_PATHS_CSV}" ]]; then
    echo "ERROR: Figure paths CSV not found: ${FIGURE_PATHS_CSV}"
    exit 1
fi
TOTAL=$(( $(wc -l < "${FIGURE_PATHS_CSV}") - 1 ))
if [[ "${TOTAL}" -le 0 ]]; then
    echo "ERROR: No data rows in ${FIGURE_PATHS_CSV}"
    exit 1
fi
MID=$(( TOTAL / 2 ))
if [[ "${HALF}" == "1" ]]; then
    START_INDEX=0;       END_INDEX=${MID};    RUN_TAG="h1"
elif [[ "${HALF}" == "2" ]]; then
    START_INDEX=${MID};  END_INDEX=${TOTAL};  RUN_TAG="h2"
else
    echo "ERROR: HALF must be 1 or 2 (got '${HALF}')"; exit 1
fi

VLLM_LOG="${LOG_DIR}/vllm_server_${RUN_TAG}.log"
LIVE_LOG="${LOG_DIR}/live_inference_${RUN_TAG}.log"
JOB_LOG="${LOG_DIR}/job_${RUN_TAG}.log"

exec > >(tee -a "${JOB_LOG}") 2>&1

cleanup() {
    echo
    echo "============================================================"
    echo "  CLEANUP (${RUN_TAG})  Time: $(date)"
    echo "============================================================"
    if [[ -n "${VLLM_PID:-}" ]]; then
        if kill -0 "${VLLM_PID}" 2>/dev/null; then
            echo "Stopping vLLM server PID ${VLLM_PID}..."
            kill "${VLLM_PID}" 2>/dev/null || true
            sleep 5
            kill -9 "${VLLM_PID}" 2>/dev/null || true
        fi
    fi
    rm -rf "${_LOCAL_SCRATCH:-/nonexistent}" 2>/dev/null || true
}
trap cleanup EXIT

echo "============================================================"
echo "  PHASE 1: Environment Setup  (HALF=${HALF}, tag=${RUN_TAG})"
echo "  Time: $(date)"
echo "============================================================"

source "${ENV_DIR}/bin/activate"

# Scratch/compile caches MUST be node-local. Lustre (/lstr) intermittently rejects
# torchinductor/triton cache-dir creation with "OSError: [Errno 19] No such device",
# which crashes vLLM at startup. Keep only HF_HOME (model weights) on /lstr.
_LOCAL_SCRATCH="/tmp/${USER}_${RUN_TAG}_${PBS_JOBID%%.*}"
export TMPDIR="${_LOCAL_SCRATCH}/tmp"
export TRITON_CACHE_DIR="${_LOCAL_SCRATCH}/triton"
export TORCHINDUCTOR_CACHE_DIR="${_LOCAL_SCRATCH}/torchinductor"
export XDG_CACHE_HOME="${_LOCAL_SCRATCH}/xdg"
export HF_HOME="./.cache/huggingface"
mkdir -p "${TMPDIR}" "${TRITON_CACHE_DIR}" "${TORCHINDUCTOR_CACHE_DIR}" "${XDG_CACHE_HOME}" "${HF_HOME}"

export PYTHONUNBUFFERED=1
export TOKENIZERS_PARALLELISM=false
export VLLM_WORKER_MULTIPROC_METHOD=spawn
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Keep startup stable + expose Python.h for Triton's JIT launcher.
export VLLM_TORCH_COMPILE_LEVEL=0
export TORCH_COMPILE_DISABLE=1
export C_INCLUDE_PATH="${PYTHON_INCLUDE}:${C_INCLUDE_PATH:-}"
export CPATH="${PYTHON_INCLUDE}:${CPATH:-}"

echo "Hostname:          $(hostname)"
echo "PBS job id:        ${PBS_JOBID:-unknown}"
echo "HALF / tag:        ${HALF} / ${RUN_TAG}"
echo "Total CSV rows:    ${TOTAL}"
echo "Index range:       [${START_INDEX}, ${END_INDEX})"
echo "Python:            $(${PYTHON_BIN} --version 2>&1)"
echo "vLLM:              $(${PYTHON_BIN} -c 'import vllm; print(vllm.__version__)')"
echo "Model path:        ${MODEL_PATH}"
echo "Served name:       ${SERVED_MODEL_NAME}"
echo "Script path:       ${SCRIPT_PATH}"
echo "System prompt:     ${SYSTEM_PROMPT_FILE}"
echo "Figure paths CSV:  ${FIGURE_PATHS_CSV}"
echo "Output dir:        ${OUTPUT_DIR}"
echo "Max model len:     ${MAX_MODEL_LEN}"
echo "GPU mem util:      ${GPU_MEMORY_UTILIZATION}"
echo "Max images:        ${MAX_IMAGES} (0 = all)"
echo "Test args:         ${TEST_ARGS}"

[[ -f "${SCRIPT_PATH}"        ]] || { echo "ERROR: script not found: ${SCRIPT_PATH}"; exit 1; }
[[ -f "${SYSTEM_PROMPT_FILE}" ]] || { echo "ERROR: system prompt not found: ${SYSTEM_PROMPT_FILE}"; exit 1; }
[[ -d "${MODEL_PATH}"         ]] || { echo "ERROR: model path not found: ${MODEL_PATH}"; exit 1; }

echo "============================================================"
echo "  PHASE 2: vLLM Server Launch (single node, TP=1, W4A16)"
echo "  Time: $(date)"
echo "============================================================"

rm -f "${VLLM_LOG}"

# NOTE: deliberately NO --tokenizer-mode mistral (HF tokenizer required for the
# Pixtral image processor), and NO --chat-template (HF tokenizer ships it).
"${PYTHON_BIN}" -m vllm.entrypoints.openai.api_server \
    --model "${MODEL_PATH}" \
    --served-model-name "${SERVED_MODEL_NAME}" \
    --host 0.0.0.0 \
    --port "${VLLM_PORT}" \
    --tensor-parallel-size 1 \
    --quantization compressed-tensors \
    --dtype float16 \
    --max-model-len "${MAX_MODEL_LEN}" \
    --max-num-batched-tokens "${MAX_NUM_BATCHED_TOKENS}" \
    --gpu-memory-utilization "${GPU_MEMORY_UTILIZATION}" \
    --max-num-seqs "${MAX_NUM_SEQS}" \
    --enforce-eager \
    --limit-mm-per-prompt '{"image":15,"video":0}' \
    --enable-log-requests \
    > "${VLLM_LOG}" 2>&1 &
VLLM_PID=$!
echo "vLLM PID: ${VLLM_PID}"
echo "vLLM log: ${VLLM_LOG}"

echo "Waiting for vLLM health endpoint..."
READY=0
for i in $(seq 1 120); do
    if ! kill -0 "${VLLM_PID}" 2>/dev/null; then
        echo "ERROR: vLLM exited before becoming ready. Last 200 lines:"
        tail -200 "${VLLM_LOG}" || true
        exit 1
    fi
    if curl -s "http://localhost:${VLLM_PORT}/health" > /dev/null 2>&1; then
        READY=1
        echo "vLLM server is ready after ~$((i * 10)) sec."
        break
    fi
    echo "Waiting for vLLM... (${i}/120, $((i * 10)) sec)"
    sleep 10
done
if [[ "${READY}" -ne 1 ]]; then
    echo "ERROR: vLLM did not become ready in 20 min. Last 200 lines:"
    tail -200 "${VLLM_LOG}" || true
    exit 1
fi

echo "Available models:"
curl -s "http://localhost:${VLLM_PORT}/v1/models" || true
echo

echo "============================================================"
echo "  PHASE 3: Variant B Multimodal SRP Inference (${RUN_TAG})"
echo "  Time: $(date)"
echo "============================================================"

cd "${CODE_DIR}"

INFERENCE_CMD=(
    "${PYTHON_BIN}" -u "${SCRIPT_PATH}"
    --start-index "${START_INDEX}"
    --end-index "${END_INDEX}"
    --run-tag "${RUN_TAG}"
    --max-images "${MAX_IMAGES}"
)
if [[ -n "${TEST_ARGS}" ]]; then
    # shellcheck disable=SC2206
    EXTRA=( ${TEST_ARGS} )
    INFERENCE_CMD+=("${EXTRA[@]}")
fi

echo "Inference command: ${INFERENCE_CMD[*]}"
"${INFERENCE_CMD[@]}" 2>&1 | tee "${LIVE_LOG}"
RUN_STATUS=${PIPESTATUS[0]}

if [[ "${RUN_STATUS}" -ne 0 ]]; then
    echo "ERROR: inference script failed with exit code ${RUN_STATUS}."
    exit "${RUN_STATUS}"
fi

echo "============================================================"
echo "  JOB COMPLETE (${RUN_TAG})  Time: $(date)"
echo "============================================================"
echo "SRPs:    ${SRP_DIR}"
echo "Reports: ${REPORT_DIR} (results_${RUN_TAG}.csv)"
echo "Logs:    ${LOG_DIR}"
